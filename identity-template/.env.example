# Katbot OpenClaw Agent Environment Variables
# Copy to .env and fill in your values. NEVER commit real keys.

# Your MetaMask wallet private key (used for SIWE authentication)
WALLET_PRIVATE_KEY=0xYourWalletPrivateKey

# Your Hyperliquid agent private key (from portfolio creation in Katbot)
KATBOT_HL_AGENT_PRIVATE_KEY=0xYourAgentPrivateKey
